CORS_ORIGIN=http://localhost:3000

# Anthropic API (required for /dev/hello-agent and future diagnosis routes)
ANTHROPIC_API_KEY=           # required; leave blank — set in .env.local
ANTHROPIC_MODEL=claude-opus-4-7   # optional override; default hardcoded in agent

# Replicate API (required for POST /photos/{photo_id}/segment)
REPLICATE_API_TOKEN=         # required; leave blank — set in .env.local
REPLICATE_SAM2_MODEL=meta/sam-2   # optional override; default hardcoded in segmenter
