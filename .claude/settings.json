{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit.sh ${tool_input.file_path}"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv run *)",
      "Bash(pnpm *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git status *)"
    ]
  }
}
