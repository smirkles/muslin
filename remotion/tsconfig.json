{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@cascade/*": ["../frontend/src/lib/cascade_player/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "remotion.config.ts",
    "../frontend/src/lib/cascade_player/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
